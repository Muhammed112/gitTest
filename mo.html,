<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>My Website</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      line-height: 1.6;
      color: #222;
      background-color: #fafafa;
    }

    header {
      background-color: #1a1a2e;
      color: #fff;
      padding: 1.5rem 2rem;
    }

    nav {
      display: flex;
      justify-content: space-between;
      align-items: center;
      max-width: 1000px;
      margin: 0 auto;
    }

    nav .logo {
      font-size: 1.4rem;
      font-weight: bold;
    }

    nav ul {
      list-style: none;
      display: flex;
      gap: 1.5rem;
    }

    nav a {
      color: #fff;
      text-decoration: none;
    }

    nav a:hover {
      text-decoration: underline;
    }

    .hero {
      text-align: center;
      padding: 4rem 2rem;
      max-width: 700px;
      margin: 0 auto;
    }

    .hero h1 {
      font-size: 2.5rem;
      margin-bottom: 1rem;
    }

    .hero p {
      font-size: 1.1rem;
      color: #555;
      margin-bottom: 1.5rem;
    }

    .button {
      display: inline-block;
      background-color: #1a1a2e;
      color: #fff;
      padding: 0.75rem 1.5rem;
      border-radius: 6px;
      text-decoration: none;
      font-weight: 600;
      transition: background-color 0.2s;
    }

    .button:hover {
      background-color: #16213e;
    }

    section {
      max-width: 1000px;
      margin: 0 auto;
      padding: 3rem 2rem;
    }

    section h2 {
      margin-bottom: 1rem;
      font-size: 1.8rem;
    }

    .cards {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 1.5rem;
      margin-top: 1.5rem;
    }

    .card {
      background: #fff;
      border-radius: 10px;
      padding: 1.5rem;
      box-shadow: 0 2px 8px rgba(0,0,0,0.06);
    }

    .card h3 {
      margin-bottom: 0.5rem;
    }

    footer {
      text-align: center;
      padding: 2rem;
      color: #888;
      font-size: 0.9rem;
      border-top: 1px solid #eee;
      margin-top: 2rem;
    }
  </style>
</head>
<body>

  <header>
    <nav>
      <div class="logo">MySite</div>
      <ul>
        <li><a href="#home">Home</a></li>
        <li><a href="#about">About</a></li>
        <li><a href="#contact">Contact</a></li>
      </ul>
    </nav>
  </header>

  <section class="hero" id="home">
    <h1>Welcome to My Website</h1>
    <p>This is a simple, clean starting point built with plain HTML and CSS. Edit this text and make it your own.</p>
    <a href="#about" class="button">Learn More</a>
  </section>

  <section id="about">
    <h2>About</h2>
    <p>This section is a great place to introduce yourself, your project, or your business. Replace this text with your own content.</p>
    <div class="cards">
      <div class="card">
        <h3>Fast</h3>
        <p>Lightweight and loads instantly, no frameworks required.</p>
      </div>
      <div class="card">
        <h3>Simple</h3>
        <p>Just one HTML file, easy to edit and understand.</p>
      </div>
      <div class="card">
        <h3>Flexible</h3>
        <p>Add your own sections, images, and styling as you go.</p>
      </div>
    </div>
  </section>

  <section id="contact">
    <h2>Contact</h2>
    <p>Want to get in touch? Replace this with your email, a contact form, or social links.</p>
  </section>

  <footer>
    &copy; 2026 MySite. All rights reserved.
  </footer>

</body>
</html>
